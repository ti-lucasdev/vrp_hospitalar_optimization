# Copie este arquivo para .env e preencha com seus valores reais.
# O .env está no .gitignore e nunca deve ser commitado.

# Chave da OpenAI (obrigatória para o módulo de IA — main_ia.py)
OPENAI_API_KEY=sk-coloque-sua-chave-aqui

# Modelo a utilizar (opcional, default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
